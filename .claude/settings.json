{
  "permissions": {
    "allow": [
      "Bash(cd *)"
    ]
  },
  "enabledPlugins": {
    "ci@ai-helpers": true,
    "superpowers@superpowers-marketplace": true,
    "coderabbit@claude-plugins-official": true,
    "workbits-sync@workbits": true,
    "ovn-sync@workbits": true
  },
  "extraKnownMarketplaces": {
    "workbits": {
      "source": {
        "source": "directory",
        "path": "$HOME/repos/workBits"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
